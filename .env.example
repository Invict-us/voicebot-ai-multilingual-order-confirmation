# ═══════════════════════════════════════════════════
# VoiceBot AI — Environment Configuration
# Copy this file to .env and fill in your real keys.
# ═══════════════════════════════════════════════════

# ── Twilio (REQUIRED) ──
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Base URL (REQUIRED) ──
# Use ngrok for local dev: https://ngrok.com
# Example: https://abc123.ngrok-free.app
BASE_URL=https://your-ngrok-or-domain.com

# ── OpenAI (OPTIONAL — improves intent detection & transcription) ──
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deepgram (OPTIONAL — better STT for Indian languages) ──
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (OPTIONAL — ultra-realistic TTS voices) ──
# Get from https://elevenlabs.io
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Security ──
# Generate with: openssl rand -hex 32
SECRET_KEY=supersecretkeychangemeinproduction

# ── Database (Optional — defaults to SQLite) ──
# DATABASE_URL=postgresql://user:pass@localhost/voicebot
